# 复制本文件为 .env 后填入真实 Key
# 创建 Key：https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-v1-在这里粘贴你的key

# OpenRouter 推荐的可选标识（会显示在你的 OpenRouter 仪表盘里）
OPENROUTER_HTTP_REFERER=https://github.com/yourname/la-vibe-itinerary
OPENROUTER_X_TITLE=LA Vibe Itinerary

# 可选：如果以后用 Google Places API 兜底
# GOOGLE_MAPS_API_KEY=
